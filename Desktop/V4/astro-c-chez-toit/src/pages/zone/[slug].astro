---
import Layout from '../../layouts/Layout.astro';
import ZoneIntervention from '../../components/ZoneIntervention.astro';
import BreadcrumbSchema from '../../components/seo/BreadcrumbSchema.astro';
import FAQSchema from '../../components/seo/FAQSchema.astro';
import { zones, type Zone } from '../../data/zones';

export function getStaticPaths() {
  return zones.map((zone) => ({
    params: { slug: zone.slug },
    props: { zone },
  }));
}

interface Props { zone: Zone }
const { zone } = Astro.props;

const title = `Couvreur ${zone.name} : toiture, démoussage & zinguerie | C CHEZ TOÎT`;
const description = `Artisan couvreur à ${zone.name} : démoussage, nettoyage haute pression, zinguerie, façade. Devis gratuit sous 24h, intervention rapide. Garantie décennale.`;
const otherZones = zones.filter((z) => z.slug !== zone.slug).slice(0, 8);

const benefits = [
  "Intervention très rapide en cas d'urgence",
  'Devis 100% gratuit sous 24h',
  'Matériaux professionnels de haute qualité',
  'Équipe expérimentée et locale',
  'Propreté du chantier garantie',
  'Garantie décennale',
];

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: "Zones d'intervention", url: '/#zones' },
  { name: zone.name, url: `/zone/${zone.slug}` },
];

const faqItems = [
  {
    question: `Intervenez-vous rapidement à ${zone.name} en cas d'urgence ?`,
    answer: `Oui, nous nous engageons à intervenir dans les plus brefs délais à ${zone.name} et alentours pour toute urgence (fuite, tuile cassée, gouttière endommagée). Notre équipe locale est mobilisable 6 jours sur 7.`,
  },
  {
    question: `Combien coûte un démoussage de toiture à ${zone.name} ?`,
    answer: `Le tarif dépend de la superficie, de l'accessibilité et de l'état de la couverture. Nous établissons un devis 100% gratuit et personnalisé sous 24h après visite ou photos de votre toiture à ${zone.name}.`,
  },
  {
    question: `Proposez-vous une garantie sur vos prestations ?`,
    answer: `Toutes nos interventions de couverture et zinguerie sont couvertes par la garantie décennale. Nos travaux de nettoyage et traitement hydrofuge sont garantis pendant 10 ans selon le produit appliqué.`,
  },
  {
    question: `Quels services proposez-vous à ${zone.name} ?`,
    answer: `À ${zone.name}, nous réalisons : démoussage et nettoyage haute pression de toiture, traitement hydrofuge, pose et réparation de zinguerie (gouttières, faîtage), nettoyage de façade, réparation de couverture et travaux de toiture neuve.`,
  },
];

const services = [
  {
    title: 'Démoussage & nettoyage',
    desc: "Élimination des mousses et lichens, traitement hydrofuge et nettoyage haute pression de votre toiture.",
    icon: 'M3 12l2-2 4 4 8-8 4 4',
  },
  {
    title: 'Zinguerie',
    desc: "Pose et réparation de gouttières, chéneaux, descentes EP et finitions zinc sur-mesure.",
    icon: 'M4 4h16v4H4zM4 10h16v4H4zM4 16h16v4H4z',
  },
  {
    title: 'Toiture & couverture',
    desc: "Rénovation complète, remplacement de tuiles, étanchéité et entretien préventif.",
    icon: 'M3 12L12 4l9 8M5 11v9h14v-9',
  },
  {
    title: 'Façade',
    desc: "Nettoyage, ravalement et traitement anti-mousse pour redonner de l'éclat à votre maison.",
    icon: 'M4 21V7l8-4 8 4v14M9 21v-6h6v6',
  },
];
---
<Layout
  title={title}
  description={description}
  useBaseHead={true}
  bodyClass="cct-zone-page wp-singular page-template-default page wp-custom-logo wp-theme-astra ehf-footer ehf-template-astra ehf-stylesheet-astra ast-desktop ast-page-builder-template ast-no-sidebar astra-4.11.11 ast-single-post ast-inherit-site-logo-transparent ast-theme-transparent-header ast-hfb-header ast-normal-title-enabled elementor-default elementor-kit-154"
  ogType="article"
>
  {/* === Schemas SEO === */}
  <BreadcrumbSchema items={breadcrumbs} />
  <FAQSchema items={faqItems} />

  <main class="cct-zp">
    <!-- HERO -->
    <section class="cct-zp__hero">
      <div class="cct-zp__hero-bg" aria-hidden="true"></div>
      <div class="cct-zp__container cct-zp__hero-inner">
        <nav class="cct-zp__breadcrumb" aria-label="Fil d'Ariane">
          <a href="/">Accueil</a>
          <span aria-hidden="true">›</span>
          <a href="/#zones">Zones d'intervention</a>
          <span aria-hidden="true">›</span>
          <span aria-current="page">{zone.name}</span>
        </nav>

        <span class="cct-zp__eyebrow">
          <svg width="21" height="8" viewBox="0 0 21 8" fill="none" aria-hidden="true">
            <path d="M7 0H13L6 8H0L7 0Z" fill="#EA559D" />
            <path d="M13 0H7L15 8H21L13 0Z" fill="#EA559D" opacity="0.6" />
          </svg>
          Zone d'intervention
        </span>

        <h1 class="cct-zp__title">
          Couvreur, démoussage & nettoyage à <span>{zone.name}</span>
        </h1>
        <p class="cct-zp__lead">
          Artisan de proximité, nous intervenons à <strong>{zone.name}</strong> et dans toute
          la périphérie toulousaine pour vos travaux de toiture, façade et zinguerie.
          Devis gratuit sous 24h, intervention rapide en cas d'urgence.
        </p>

        <div class="cct-zp__cta-row">
          <a href="/contact" class="cct-btn cct-btn--primary">
            Demander un devis gratuit
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="tel:+33000000000" class="cct-btn cct-btn--ghost">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.86 19.86 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.86 19.86 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7a2 2 0 0 1 1.72 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Nous appeler
          </a>
        </div>
      </div>
    </section>

    <!-- INTRO + ENGAGEMENTS -->
    <section class="cct-zp__content">
      <div class="cct-zp__container cct-zp__grid">
        <div class="cct-zp__story">
          <h2>Votre artisan couvreur de proximité à {zone.name}</h2>
          <p>
            Vous résidez à <strong>{zone.name}</strong> ou dans les environs et vous recherchez
            un professionnel fiable pour entretenir, rénover ou réparer votre toiture ?
            <strong>C CHEZ TOÎT</strong> est votre partenaire local de confiance.
          </p>
          <p>
            La toiture et la façade sont les premiers remparts de votre habitation. Avec le
            climat de la région toulousaine, mousses, lichens et salissures s'accumulent
            rapidement. Nous intervenons à {zone.name} pour le démoussage, le nettoyage haute
            pression, la pose de zinguerie et tous les travaux de couverture.
          </p>
          <p>
            En cas d'urgence — fuite, tuile cassée, gouttière endommagée — notre réactivité
            nous permet d'être sur place dans les plus brefs délais pour sécuriser votre
            couverture et éviter tout dégât d'eau.
          </p>
        </div>

        <aside class="cct-zp__card">
          <div class="cct-zp__card-blob" aria-hidden="true"></div>
          <h3>Nos engagements</h3>
          <ul role="list">
            {benefits.map((b) => (
              <li>
                <span class="cct-check" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                    <path d="M4 12l5 5L20 6" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
          <a href="/contact" class="cct-btn cct-btn--primary cct-btn--block">
            Devis gratuit à {zone.name}
          </a>
          <p class="cct-zp__card-note">Réponse rapide garantie sous 24h</p>
        </aside>
      </div>
    </section>

    <!-- SERVICES -->
    <section class="cct-zp__services">
      <div class="cct-zp__container">
        <header class="cct-zp__sec-header">
          <span class="cct-zp__eyebrow cct-zp__eyebrow--center">Nos services à {zone.name}</span>
          <h2>Une expertise complète pour votre maison</h2>
        </header>
        <div class="cct-zp__services-grid">
          {services.map((s) => (
            <article class="cct-svc-card">
              <span class="cct-svc-card__icon" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                  <path d={s.icon} stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- AUTRES ZONES -->
    <section class="cct-zp__others">
      <div class="cct-zp__container">
        <header class="cct-zp__sec-header">
          <span class="cct-zp__eyebrow cct-zp__eyebrow--center">Autres communes</span>
          <h2>Nous intervenons aussi près de chez vous</h2>
        </header>
        <ul class="cct-zp__others-list" role="list">
          {otherZones.map((z) => (
            <li>
              <a href={`/zone/${z.slug}`}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7Zm0 9.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5Z" fill="currentColor"/>
                </svg>
                {z.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- FAQ -->
    <section class="cct-zp__faq">
      <div class="cct-zp__container">
        <header class="cct-zp__sec-header">
          <span class="cct-zp__eyebrow cct-zp__eyebrow--center">Questions fréquentes</span>
          <h2>Vos questions sur nos interventions à {zone.name}</h2>
        </header>
        <div class="cct-zp__faq-list">
          {faqItems.map((qa, i) => (
            <details class="cct-faq" open={i === 0}>
              <summary>
                <span>{qa.question}</span>
                <span class="cct-faq__icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                    <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </summary>
              <div class="cct-faq__answer">
                <p>{qa.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- SECTION COMPLETE -->
    <ZoneIntervention variant="soft" title="Toutes nos zones d'intervention" />
  </main>
</Layout>

<style>
  /* Reset minimal pour eviter les conflits avec Astra */
  .cct-zp,
  .cct-zp * { box-sizing: border-box; }

  .cct-zp {
    font-family: 'Roboto', system-ui, sans-serif;
    color: #000422;
    background: #ffffff;
  }
  .cct-zp h1, .cct-zp h2, .cct-zp h3 {
    font-family: 'Roboto Slab', 'Roboto', serif;
    color: #000422;
    line-height: 1.2;
    margin: 0;
  }

  .cct-zp__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* HERO - identique a /projets : image sombre + navbar transparente blanche */
  .cct-zp__hero {
    position: relative;
    padding: 200px 0 100px;
    overflow: hidden;
    isolation: isolate;
  }
  .cct-zp__hero-bg {
    position: absolute; inset: 0; z-index: -1;
    background-image:
      linear-gradient(rgba(0, 4, 34, 0.55), rgba(0, 4, 34, 0.55)),
      url('/assets/wp-content/uploads/2025/12/banner-projet-toiture.png');
    background-size: cover;
    background-position: center;
  }

  .cct-zp__hero-inner {
    text-align: center;
  }
  .cct-zp__breadcrumb {
    display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 8px;
    font-size: 13px; color: rgba(255,255,255,0.85); margin-bottom: 32px;
  }
  .cct-zp__breadcrumb a { color: rgba(255,255,255,0.85); text-decoration: none; }
  .cct-zp__breadcrumb a:hover { color: #EA559D; }
  .cct-zp__breadcrumb [aria-current] { color: #EA559D; font-weight: 600; }

  .cct-zp__eyebrow {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 13px; font-weight: 700; letter-spacing: 0.18em;
    text-transform: uppercase; color: #EA559D;
    margin-bottom: 18px;
  }
  .cct-zp__eyebrow--center { display: inline-flex; }

  .cct-zp__hero .cct-zp__title {
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 700; line-height: 1.1;
    margin: 0 auto 22px; max-width: 22ch;
    color: #ffffff;
  }
  .cct-zp__hero .cct-zp__title span { color: #EA559D; }

  .cct-zp__hero .cct-zp__lead {
    font-size: 18px; line-height: 1.65; color: rgba(255,255,255,0.92);
    max-width: 60ch; margin: 0 auto 36px;
  }

  .cct-zp__cta-row {
    display: flex; flex-wrap: wrap; gap: 14px; justify-content: center;
  }

  .cct-btn {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 14px 26px; border-radius: 999px;
    font-weight: 700; font-size: 15px; letter-spacing: 0.01em;
    text-decoration: none; cursor: pointer;
    transition: transform .2s ease, box-shadow .2s ease,
                background .2s ease, color .2s ease, border-color .2s ease;
    border: 2px solid transparent;
  }
  .cct-btn--primary {
    background: #EA559D; color: #fff;
    box-shadow: 0 10px 24px -10px rgba(234, 85, 157, .65);
  }
  .cct-btn--primary:hover {
    background: #c93d83; transform: translateY(-2px);
    box-shadow: 0 14px 30px -12px rgba(234, 85, 157, .8);
  }
  .cct-btn--ghost {
    background: #ffffff; color: #000422;
    border-color: #f0b7d5;
  }
  .cct-btn--ghost:hover {
    border-color: #EA559D; color: #EA559D;
    transform: translateY(-2px);
  }
  .cct-btn--block { display: flex; width: 100%; justify-content: center; margin-top: 8px; }

  /* CONTENT */
  .cct-zp__content { padding: 80px 0; background: #ffffff; }
  .cct-zp__grid {
    display: grid; gap: 48px; align-items: start;
  }
  @media (min-width: 900px) {
    .cct-zp__grid { grid-template-columns: 1.2fr 1fr; gap: 64px; }
  }
  .cct-zp__story h2 {
    font-size: clamp(24px, 3vw, 34px);
    margin-bottom: 24px;
  }
  .cct-zp__story p {
    color: #454f5e; line-height: 1.75; font-size: 16px; margin: 0 0 18px;
  }
  .cct-zp__story strong { color: #000422; }

  .cct-zp__card {
    position: relative;
    background: linear-gradient(180deg, #fceef5 0%, #ffffff 100%);
    border: 1px solid #f1d6e4;
    border-radius: 24px;
    padding: 36px 32px;
    box-shadow: 0 30px 60px -40px rgba(234, 85, 157, .35);
    overflow: hidden;
  }
  .cct-zp__card-blob {
    position: absolute; top: -60px; right: -60px;
    width: 220px; height: 220px;
    background: radial-gradient(circle, rgba(234,85,157,.25), transparent 70%);
    filter: blur(20px); pointer-events: none;
  }
  .cct-zp__card h3 {
    font-size: 22px; margin-bottom: 22px;
  }
  .cct-zp__card ul {
    list-style: none; padding: 0; margin: 0 0 28px;
    display: grid; gap: 12px;
  }
  .cct-zp__card li {
    display: flex; align-items: center; gap: 14px;
    background: #ffffff; padding: 14px 18px;
    border-radius: 14px; border: 1px solid #f4e4ed;
    font-size: 15px; font-weight: 500; color: #000422;
  }
  .cct-check {
    width: 28px; height: 28px; border-radius: 50%;
    background: #EA559D; color: #fff;
    display: inline-flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .cct-zp__card-note {
    text-align: center; font-size: 12px; color: #454f5e;
    margin: 12px 0 0;
  }

  /* SERVICES */
  .cct-zp__services { padding: 80px 0; background: #fafafa; }
  .cct-zp__sec-header { text-align: center; margin: 0 auto 48px; max-width: 720px; }
  .cct-zp__sec-header h2 { font-size: clamp(26px, 3.4vw, 38px); margin-top: 8px; }

  .cct-zp__services-grid {
    display: grid; gap: 18px;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }
  .cct-svc-card {
    background: #ffffff; border: 1px solid #eef2f6;
    border-radius: 20px; padding: 28px 24px;
    transition: transform .25s ease, border-color .25s ease, box-shadow .25s ease;
  }
  .cct-svc-card:hover {
    transform: translateY(-4px);
    border-color: #f0b7d5;
    box-shadow: 0 20px 40px -24px rgba(234, 85, 157, .35);
  }
  .cct-svc-card__icon {
    width: 48px; height: 48px; border-radius: 14px;
    background: #fceef5; color: #EA559D;
    display: inline-flex; align-items: center; justify-content: center;
    margin-bottom: 18px;
  }
  .cct-svc-card h3 { font-size: 19px; margin-bottom: 8px; }
  .cct-svc-card p {
    color: #454f5e; line-height: 1.6; font-size: 15px; margin: 0;
  }

  /* AUTRES ZONES */
  .cct-zp__others { padding: 80px 0; background: #ffffff; }
  .cct-zp__others-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-wrap: wrap; gap: 10px; justify-content: center;
  }
  .cct-zp__others-list a {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 18px; border-radius: 999px;
    background: #ffffff; border: 1px solid #f1d6e4;
    color: #000422; text-decoration: none;
    font-weight: 500; font-size: 14px;
    transition: all .2s ease;
  }
  .cct-zp__others-list a:hover {
    background: #EA559D; color: #fff; border-color: #EA559D;
    transform: translateY(-2px);
  }
  .cct-zp__others-list a svg { color: #EA559D; transition: color .2s ease; }
  .cct-zp__others-list a:hover svg { color: #fff; }

  /* FAQ accordion */
  .cct-zp__faq { padding: 80px 0; background: #fafafa; }
  .cct-zp__faq-list {
    max-width: 820px; margin: 0 auto;
    display: grid; gap: 12px;
  }
  .cct-faq {
    background: #ffffff;
    border: 1px solid #f1d6e4;
    border-radius: 16px;
    overflow: hidden;
    transition: border-color .25s ease, box-shadow .25s ease;
  }
  .cct-faq[open] {
    border-color: #EA559D;
    box-shadow: 0 12px 28px -16px rgba(234, 85, 157, 0.35);
  }
  .cct-faq summary {
    display: flex; align-items: center; gap: 16px;
    padding: 20px 24px;
    font-weight: 600; font-size: 16px;
    color: #000422;
    cursor: pointer; list-style: none;
    user-select: none;
  }
  .cct-faq summary::-webkit-details-marker { display: none; }
  .cct-faq summary > span:first-child { flex: 1; line-height: 1.4; }
  .cct-faq__icon {
    width: 32px; height: 32px; border-radius: 50%;
    background: #fceef5; color: #EA559D;
    display: inline-flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: transform .25s ease, background .25s ease, color .25s ease;
  }
  .cct-faq[open] .cct-faq__icon {
    background: #EA559D; color: #fff;
    transform: rotate(180deg);
  }
  .cct-faq summary:hover .cct-faq__icon {
    background: #EA559D; color: #fff;
  }
  .cct-faq__answer {
    padding: 0 24px 22px; color: #454f5e;
    line-height: 1.7; font-size: 15px;
  }
  .cct-faq__answer p { margin: 0; }

  /* ===== RESPONSIVE MOBILE pour les pages zones ===== */
  @media (max-width: 768px) {
    .cct-zp__hero {
      padding: 140px 0 60px;
    }
    .cct-zp__hero .cct-zp__title {
      font-size: clamp(28px, 8vw, 40px);
      max-width: 100%;
    }
    .cct-zp__hero .cct-zp__lead {
      font-size: 16px;
      padding: 0 8px;
    }
    .cct-zp__breadcrumb {
      font-size: 12px;
      margin-bottom: 24px;
    }
    .cct-zp__cta-row {
      flex-direction: column;
      gap: 10px;
    }
    .cct-btn {
      width: 100%;
      justify-content: center;
    }

    .cct-zp__content,
    .cct-zp__services,
    .cct-zp__others,
    .cct-zp__faq {
      padding: 48px 0;
    }
    .cct-zp__sec-header h2 {
      font-size: 26px;
    }
    .cct-zp__card {
      padding: 24px 20px;
      border-radius: 18px;
    }
    .cct-zp__card h3 {
      font-size: 20px;
    }
    .cct-services-grid {
      grid-template-columns: 1fr !important;
    }
    .cct-svc-card {
      padding: 22px 18px;
    }
    .cct-zp__others-list a {
      font-size: 13px;
      padding: 8px 14px;
    }
    .cct-faq summary {
      padding: 16px 18px;
      font-size: 15px;
    }
    .cct-faq__answer {
